# Telegram-Kiro-Bot Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================================================

# Telegram Bot Token (get from @BotFather on Telegram)
# Create a new bot: /newbot -> follow instructions -> copy token
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-REPLACE-ME

# Comma-separated list of Telegram user IDs allowed to use the bot
# Get your user ID by messaging @userinfobot on Telegram
ALLOWED_USERS=123456789,987654321

# Path to Kiro CLI executable
# Install Kiro CLI and provide the full path to the binary
KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Path to workspace directory containing .kiro/ configuration
# This should be the root directory of your development project
WORKSPACE_PATH=/home/ubuntu/workspace

# ============================================================================
# MCP SERVER TOKENS (Required for agent functionality)
# ============================================================================

# GitHub Personal Access Token (required for all agents)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Configuration (required for backend and testing agents)
# Get from your Supabase project dashboard -> Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# Vercel Token (required for frontend and devops agents)
# Create at: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token-here

# ============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# ============================================================================

# Telegram chat ID for system notifications (optional)
# If not set, notifications will be disabled
# Get by messaging @userinfobot or check chat info in Telegram
NOTIFY_CHAT_ID=123456789

# Logging configuration
LOG_DIR=./logs
LOG_MAX_SIZE_MB=10
LOG_RETAIN_DAYS=7

# Progress notification interval (seconds)
# How often to send "still running..." messages for long tasks
PROGRESS_INTERVAL_SEC=30

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Create Telegram bot with @BotFather
# 4. Get your user ID from @userinfobot
# 5. Create GitHub token with repo permissions
# 6. Set up Supabase project and get API credentials
# 7. Create Vercel token for deployments
# 8. Install dependencies: npm install
# 9. Start with PM2: pm2 start ecosystem.config.js
#
# For detailed setup instructions, see README.md